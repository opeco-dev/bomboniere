generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("user") // admin, funcionario, cliente
  ativo     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente   Cliente?
}

model Cliente {
  id                  String   @id @default(cuid())
  usuarioId           String?  @unique

  nome                String
  telefone            String
  email               String?

  setor               String?
  limiteCredito       Float    @default(0)
  quantidadePedidos   Int      @default(0)

  ativo               Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  usuario             Usuario? @relation(fields: [usuarioId], references: [id])
  vendas              Venda[]
  contasReceber       ContaReceber[]
}

model Produto {
  id          Int   @id @default(autoincrement())
  nome        String
  descricao   String?
  categoria   String

  preco       Float
  custoUnit   Float

  unidade     String   @default("un") // un, kg, caixa
  estoqueMin  Int
  ativo       Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  imagens     ProdutoImagem[]

  estoque     Estoque[]
  itensVenda  ItemVenda[]
}

model ProdutoImagem {
  id        Int     @id @default(autoincrement())
  url       String
  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

model Estoque {
  id            String   @id @default(cuid())
  produtoId     Int

  quantidade    Int
  lote          String?
  dataValidade  DateTime?
  localizacao   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  produto       Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

model Venda {
  id          String   @id @default(cuid())
  clienteId   String?

  total       Float
  desconto    Float    @default(0)
  
  ativo      Boolean  @default(true)
  status      String   @default("aberta") // aberta, finalizada, cancelada
  observacoes String?
  
  pagamentoId String?
  dataVenda   DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente? @relation(fields: [clienteId], references: [id])

  itens       ItemVenda[]
  contas      ContaReceber[]
}

model ItemVenda {
  id          String   @id @default(cuid())
  vendaId     String
  produtoId   Int

  quantidade  Int
  precoUnit   Float
  subtotal    Float

  venda       Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto     Produto  @relation(fields: [produtoId], references: [id])
}

model ContaReceber {
  id              String   @id @default(cuid())
  vendaId         String
  clienteId       String

  valorTotal      Float
  valorPago       Float    @default(0)
  saldo           Float

  status          String   @default("pendente") // pendente, parcial, pago, cancelado

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  venda           Venda    @relation(fields: [vendaId], references: [id])
  cliente         Cliente  @relation(fields: [clienteId], references: [id])

  parcelas        Parcela[]
}

model Parcela {
  id              String   @id @default(cuid())
  contaId         String

  numeroParcela   Int
  valor           Float

  dataVencimento  DateTime
  status          String   @default("pendente") // pendente, pago, atrasado

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conta           ContaReceber @relation(fields: [contaId], references: [id], onDelete: Cascade)

  pagamentos      Pagamento[]
}

model Pagamento {
  id                String   @id @default(cuid())
  parcelaId         String

  valor             Float
  metodoPagamento   String // dinheiro, pix, debito, credito

  dataPagamento     DateTime @default(now())
  observacoes       String?

  createdAt         DateTime @default(now())

  parcela           Parcela  @relation(fields: [parcelaId], references: [id])
}
