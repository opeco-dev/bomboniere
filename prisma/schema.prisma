generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("user")
  ativo     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente   Cliente?
}

model Cliente {
  id                String   @id @default(cuid())
  usuarioId         String?  @unique

  nome              String
  telefone          String
  email             String?

  setor             String?
  limiteCredito     Float    @default(0)
  quantidadePedidos Int      @default(0)

  ativo             Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  usuario           Usuario? @relation(fields: [usuarioId], references: [id])
  vendas            Venda[]
  contasReceber     ContaReceber[]
}

model Produto {
  id          Int   @id @default(autoincrement())
  nome        String
  descricao   String?
  categoria   String

  preco       Float
  custoUnit   Float

  unidade     String   @default("un")
  estoqueMin  Int
  ativo       Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imagens     ProdutoImagem[]
  variacoes   ProdutoVariacao[]

  estoque     Estoque[]
  itensVenda  ItemVenda[]
}

model ProdutoImagem {
  id        Int     @id @default(autoincrement())
  url       String
  fileKey   String?
  produtoId Int
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

model ProdutoVariacao {
  id         Int      @id @default(autoincrement())
  produtoId  Int
  sabor      String
  preco      Float?
  ativo      Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  produto    Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  imagens    ProdutoVariacaoImagem[]
  estoque    Estoque[]
  itensVenda ItemVenda[]

  @@index([produtoId])
}

model ProdutoVariacaoImagem {
  id         Int             @id @default(autoincrement())
  url        String
  fileKey    String?
  variacaoId Int
  variacao   ProdutoVariacao @relation(fields: [variacaoId], references: [id], onDelete: Cascade)
}

model Estoque {
  id            String   @id @default(cuid())
  produtoId     Int
  variacaoId    Int?

  quantidade    Int
  lote          String?
  dataValidade  DateTime?
  localizacao   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  produto       Produto          @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  variacao      ProdutoVariacao? @relation(fields: [variacaoId], references: [id], onDelete: Cascade)

  @@index([produtoId])
  @@index([variacaoId])
}

model Venda {
  id          String   @id @default(cuid())
  clienteId   String?

  total       Float
  desconto    Float    @default(0)

  ativo       Boolean  @default(true)
  status      String   @default("aberta")
  observacoes String?

  pagamentoId String?  @unique
  dataVenda   DateTime @default(now())
  pixExpiraEm DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente? @relation(fields: [clienteId], references: [id])

  itens       ItemVenda[]
  contas      ContaReceber[]
}

model ItemVenda {
  id             String   @id @default(cuid())
  vendaId        String
  produtoId      Int
  variacaoId     Int?
  saborSnapshot  String?

  quantidade     Int
  precoUnit      Float
  subtotal       Float

  venda          Venda            @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto        Produto          @relation(fields: [produtoId], references: [id])
  variacao       ProdutoVariacao? @relation(fields: [variacaoId], references: [id])
}

model ContaReceber {
  id          String   @id @default(cuid())
  vendaId     String
  clienteId   String

  valorTotal  Float
  valorPago   Float    @default(0)
  saldo       Float

  status      String   @default("pendente")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venda       Venda    @relation(fields: [vendaId], references: [id])
  cliente     Cliente  @relation(fields: [clienteId], references: [id])

  parcelas    Parcela[]
}

model Parcela {
  id             String   @id @default(cuid())
  contaId        String

  numeroParcela  Int
  valor          Float

  dataVencimento DateTime
  status         String   @default("pendente")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conta          ContaReceber @relation(fields: [contaId], references: [id], onDelete: Cascade)

  pagamentos     Pagamento[]
}

model Pagamento {
  id              String   @id @default(cuid())
  parcelaId       String

  valor           Float
  metodoPagamento String

  dataPagamento   DateTime @default(now())
  observacoes     String?

  createdAt       DateTime @default(now())

  parcela         Parcela  @relation(fields: [parcelaId], references: [id])
}
